# DevLoop API environment template
# Copy to .env (which is gitignored) and edit for your environment.

# --- Runtime ---
NODE_ENV=development
DEVLOOP_API_HOST=127.0.0.1
DEVLOOP_API_PORT=3100

# --- Database ---
# Fas 0.2+ uses Unix socket peer authentication (see ARCHITECTURE.md §11).
# No password needed; the OS user running the process determines the PG role
# via pg_ident.conf mapping. Both roles are LOGIN-enabled:
#
#   devloop_owner — LOGIN role, used ONLY by devloop-admin OS user for migrations
#   devloop_api   — LOGIN role, used by devloop-api OS user at runtime
#
# DEVLOOP_DB_USER is intentionally left BLANK here to force an explicit choice
# per process. Set it to exactly one of:
#   DEVLOOP_DB_USER=devloop_owner   (for migrations — sudo -u devloop-admin ...)
#   DEVLOOP_DB_USER=devloop_api     (for runtime    — sudo -u devloop-api ...)
DEVLOOP_DB_SOCKET_DIR=/var/run/postgresql
DEVLOOP_DB_NAME=devloop
DEVLOOP_DB_USER=

# --- Explicit synchronize guard (must not be 'true' outside dev) ---
# Never set in production. TypeORM synchronize is disabled in data-source.ts
# regardless of this flag; these env vars trigger the startup refusal in main.ts
# if set in a non-development environment.
# TYPEORM_SYNCHRONIZE=false
# DB_SYNCHRONIZE=false
